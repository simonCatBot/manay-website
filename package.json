{
  "name": "manay-website-tests",
  "version": "1.0.0",
  "description": "Testing suite for Manay website",
  "scripts": {
    "test": "npm run test:html && npm run test:accessibility && npm run test:links",
    "test:html": "npx html-validate '*.html'",
    "test:accessibility": "npx pa11y-ci --config .pa11y-ci.json",
    "test:links": "npx link-checker --url . --file-ignore 'node_modules/**'",
    "test:css": "npx stylelint '*.css'",
    "test:js": "npx eslint script.js",
    "lighthouse": "npx lighthouse-ci"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "html-validate": "^8.0.0",
    "lighthouse-ci": "^1.0.0",
    "pa11y-ci": "^3.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
